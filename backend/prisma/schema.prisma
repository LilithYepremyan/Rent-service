generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"               // указываем postgresql
  url      = env("DATABASE_URL")    // обязательно!
}

model Cloth {
  id          Int          @id @default(autoincrement())
  code        String       @unique
  name        String
  color       String
  price       Float
  photos      Photo[]
  status      ClothStatus  @default(AVAILABLE)
  rentals     Rental[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  

  @@index([code])
  @@index([status])
}

model Customer {
  id          Int      @id @default(autoincrement())
  firstName   String
  lastName    String
  phone       String
  passport    String   @unique
  deposit     Float
  description String?
  rentals     Rental[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([phone])
}

model Photo {
  id      Int    @id @default(autoincrement())
  url     String
  clothId Int
  cloth   Cloth  @relation(fields: [clothId], references: [id], onDelete: Cascade)
}

model Rental {
  id         Int          @id @default(autoincrement())
  startDate  DateTime
  endDate    DateTime
  rentDate   DateTime
  clothId    Int
  status     RentalStatus @default(RESERVED)
  customerId Int 
  
  cloth      Cloth    @relation(fields: [clothId], references: [id], onDelete: Restrict)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clothId])
  @@index([customerId])
  @@unique([clothId, rentDate])

}

enum ClothStatus {
  AVAILABLE
  RESERVED
  RENTED
  CLEANING
  DAMAGED
  UNAVAILABLE
  ARCHIVED
}

enum RentalStatus {
  RESERVED
  CLEANING
  RENTED
  RETURNED
  CANCELLED
}
